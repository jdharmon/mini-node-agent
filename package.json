{
  "name": "mini-node-agent",
  "version": "0.1.0",
  "description": "A minimal Node.js software engineering agent inspired by mini-swe-agent.",
  "type": "module",
  "bin": {
    "mini-node-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.3",
    "commander": "^12.1.0",
    "openai": "^4.104.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
